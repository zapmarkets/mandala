# ============================================================
# Mandala Protocol — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- RPC ---
BASE_SEPOLIA_RPC=https://sepolia.base.org
RPC_URL_BASE_SEPOLIA=https://sepolia.base.org
RPC_URL_BASE_MAINNET=https://mainnet.base.org

# --- Deployer / Default Private Key ---
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# --- Multi-Agent Keys (for demo scripts) ---
# Each agent needs its own funded wallet on Base Sepolia
COORDINATOR_KEY=0xCOORDINATOR_PRIVATE_KEY
WORKER_A_KEY=0xWORKER_A_PRIVATE_KEY
WORKER_B_KEY=0xWORKER_B_PRIVATE_KEY
VERIFIER_KEY=0xVERIFIER_PRIVATE_KEY

# --- Deployed Contract Addresses (fill after deploy) ---
POLICY_ADDRESS=0x...
REGISTRY_ADDRESS=0x...
FACTORY_ADDRESS=0x...
TASK_IMPL_ADDRESS=0x...

# --- Treasury (defaults to deployer if not set) ---
TREASURY_ADDRESS=0x...

# --- Basescan (for contract verification) ---
BASESCAN_API_KEY=your_basescan_api_key_here
